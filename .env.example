#
# Required for Firebase Admin SDK in backend API routes.
# Copy these keys to .env.local using your Firebase service account values.
#
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

NEXT_PUBLIC_ESP32_BLE_SERVICE_UUID=00000000-0000-1000-8000-00805f9b34fb
NEXT_PUBLIC_ESP32_BLE_CHARACTERISTIC_UUID=00000001-0000-1000-8000-00805f9b34fb
